{
  "name": "@fasl-work/caos-app-shell",
  "version": "0.2.0",
  "description": "Shared web-app shell + content primitives + design system for the CAOS / Faena public apps (ADR-0016).",
  "license": "MIT",
  "author": "Felipe Santibáñez-Leal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fsantibanezleal/CAOS_APP_SHELL.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --import tsx --test test/vizLoop.test.ts test/caseModel.test.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "katex": "^0.16.0",
    "lucide-react": ">=0.400.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-router-dom": "^6 || ^7",
    "zustand": "^4 || ^5"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "katex": "^0.16.11",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "zustand": "^5.0.2"
  }
}
